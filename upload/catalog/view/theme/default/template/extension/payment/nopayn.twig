<p>{{ text_redirect }}</p>

{% if enabled_methods|length > 1 %}
<p><strong>{{ text_select_payment_method }}</strong></p>
{% for enabled_method in enabled_methods %}
<div class="radio">
  <label>
    <input type="radio" name="nopayn_method" value="{{ enabled_method.code }}" {% if enabled_method.code == selected_method %}checked="checked"{% endif %} />
    {{ enabled_method.title }}
  </label>
</div>
{% endfor %}
{% else %}
<input type="hidden" name="nopayn_method" value="{{ selected_method }}" />
<p><strong>{{ enabled_methods[0].title }}</strong></p>
{% endif %}

<div class="buttons">
  <div class="pull-right">
    <input type="button" value="{{ button_confirm }}" id="button-confirm" data-loading-text="{{ text_loading }}" class="btn btn-primary" />
  </div>
</div>

<script type="text/javascript"><!--
$('#button-confirm').bind('click', function() {
	$.ajax({
		url: '{{ confirm_url }}',
		type: 'post',
		data: $('input[name=\'nopayn_method\']:checked, input[name=\'nopayn_method\'][type=\'hidden\']'),
		dataType: 'json',
		beforeSend: function() {
			$('#button-confirm').button('loading');
			$('.alert-dismissible').remove();
		},
		complete: function() {
			$('#button-confirm').button('reset');
		},
		success: function(json) {
			if (json['error']) {
				$('#button-confirm').closest('.buttons').before('<div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> ' + json['error'] + '<button type="button" class="close" data-dismiss="alert">&times;</button></div>');
			}

			if (json['redirect']) {
				location = json['redirect'];
			}
		},
		error: function(xhr, ajaxOptions, thrownError) {
			console.log(thrownError + "\r\n" + xhr.statusText + "\r\n" + xhr.responseText);
		}
	});
});
//--></script>
