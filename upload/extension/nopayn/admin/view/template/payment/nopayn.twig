{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="float-end">
        <button type="submit" form="form-payment" data-bs-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa-solid fa-save"></i></button>
        <a href="{{ back }}" data-bs-toggle="tooltip" title="{{ button_back }}" class="btn btn-light"><i class="fa-solid fa-reply"></i></a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ol class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li class="breadcrumb-item"><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ol>
    </div>
  </div>
  <div class="container-fluid">
    <div class="card">
      <div class="card-header"><i class="fa-solid fa-pencil"></i> {{ text_edit }}</div>
      <div class="card-body">
        <form id="form-payment" action="{{ save }}" method="post" data-oc-toggle="ajax">

          <div class="row mb-3">
            <label for="input-api-key" class="col-sm-2 col-form-label">{{ entry_api_key }}</label>
            <div class="col-sm-10">
              <input type="text" name="payment_nopayn_api_key" value="{{ payment_nopayn_api_key }}" id="input-api-key" class="form-control" />
              <div class="form-text">{{ entry_api_key_help }}</div>
            </div>
          </div>

          <fieldset>
            <legend>{{ text_payment_methods }}</legend>
            <div class="form-text mb-3">{{ text_payment_methods_help }}</div>

            <div class="row mb-3">
              <label class="col-sm-2 col-form-label">{{ entry_creditcard }}</label>
              <div class="col-sm-10">
                <div class="form-check form-switch form-switch-lg">
                  <input type="hidden" name="payment_nopayn_creditcard" value="0" />
                  <input type="checkbox" name="payment_nopayn_creditcard" value="1" id="input-creditcard" class="form-check-input"{% if payment_nopayn_creditcard %} checked{% endif %} />
                </div>
              </div>
            </div>

            <div class="row mb-3">
              <label class="col-sm-2 col-form-label">{{ entry_applepay }}</label>
              <div class="col-sm-10">
                <div class="form-check form-switch form-switch-lg">
                  <input type="hidden" name="payment_nopayn_applepay" value="0" />
                  <input type="checkbox" name="payment_nopayn_applepay" value="1" id="input-applepay" class="form-check-input"{% if payment_nopayn_applepay %} checked{% endif %} />
                </div>
              </div>
            </div>

            <div class="row mb-3">
              <label class="col-sm-2 col-form-label">{{ entry_googlepay }}</label>
              <div class="col-sm-10">
                <div class="form-check form-switch form-switch-lg">
                  <input type="hidden" name="payment_nopayn_googlepay" value="0" />
                  <input type="checkbox" name="payment_nopayn_googlepay" value="1" id="input-googlepay" class="form-check-input"{% if payment_nopayn_googlepay %} checked{% endif %} />
                </div>
              </div>
            </div>

            <div class="row mb-3">
              <label class="col-sm-2 col-form-label">{{ entry_mobilepay }}</label>
              <div class="col-sm-10">
                <div class="form-check form-switch form-switch-lg">
                  <input type="hidden" name="payment_nopayn_mobilepay" value="0" />
                  <input type="checkbox" name="payment_nopayn_mobilepay" value="1" id="input-mobilepay" class="form-check-input"{% if payment_nopayn_mobilepay %} checked{% endif %} />
                </div>
              </div>
            </div>
          </fieldset>

          <div class="row mb-3">
            <label for="input-order-status" class="col-sm-2 col-form-label">{{ entry_order_status }}</label>
            <div class="col-sm-10">
              <select name="payment_nopayn_order_status_id" id="input-order-status" class="form-select">
                {% for order_status in order_statuses %}
                  <option value="{{ order_status.order_status_id }}"{% if order_status.order_status_id == payment_nopayn_order_status_id %} selected{% endif %}>{{ order_status.name }}</option>
                {% endfor %}
              </select>
              <div class="form-text">{{ entry_order_status_help }}</div>
            </div>
          </div>

          <div class="row mb-3">
            <label for="input-pending-status" class="col-sm-2 col-form-label">{{ entry_pending_status }}</label>
            <div class="col-sm-10">
              <select name="payment_nopayn_pending_status_id" id="input-pending-status" class="form-select">
                {% for order_status in order_statuses %}
                  <option value="{{ order_status.order_status_id }}"{% if order_status.order_status_id == payment_nopayn_pending_status_id %} selected{% endif %}>{{ order_status.name }}</option>
                {% endfor %}
              </select>
              <div class="form-text">{{ entry_pending_status_help }}</div>
            </div>
          </div>

          <div class="row mb-3">
            <label for="input-cancelled-status" class="col-sm-2 col-form-label">{{ entry_cancelled_status }}</label>
            <div class="col-sm-10">
              <select name="payment_nopayn_cancelled_status_id" id="input-cancelled-status" class="form-select">
                {% for order_status in order_statuses %}
                  <option value="{{ order_status.order_status_id }}"{% if order_status.order_status_id == payment_nopayn_cancelled_status_id %} selected{% endif %}>{{ order_status.name }}</option>
                {% endfor %}
              </select>
              <div class="form-text">{{ entry_cancelled_status_help }}</div>
            </div>
          </div>

          <div class="row mb-3">
            <label for="input-geo-zone" class="col-sm-2 col-form-label">{{ entry_geo_zone }}</label>
            <div class="col-sm-10">
              <select name="payment_nopayn_geo_zone_id" id="input-geo-zone" class="form-select">
                <option value="0">{{ text_all_zones }}</option>
                {% for geo_zone in geo_zones %}
                  <option value="{{ geo_zone.geo_zone_id }}"{% if geo_zone.geo_zone_id == payment_nopayn_geo_zone_id %} selected{% endif %}>{{ geo_zone.name }}</option>
                {% endfor %}
              </select>
            </div>
          </div>

          <div class="row mb-3">
            <label for="input-status" class="col-sm-2 col-form-label">{{ entry_status }}</label>
            <div class="col-sm-10">
              <div class="form-check form-switch form-switch-lg">
                <input type="hidden" name="payment_nopayn_status" value="0" />
                <input type="checkbox" name="payment_nopayn_status" value="1" id="input-status" class="form-check-input"{% if payment_nopayn_status %} checked{% endif %} />
              </div>
            </div>
          </div>

          <div class="row mb-3">
            <label for="input-sort-order" class="col-sm-2 col-form-label">{{ entry_sort_order }}</label>
            <div class="col-sm-10">
              <input type="text" name="payment_nopayn_sort_order" value="{{ payment_nopayn_sort_order }}" id="input-sort-order" class="form-control" />
            </div>
          </div>

        </form>
      </div>
    </div>
  </div>
</div>
{{ footer }}
